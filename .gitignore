# 폴더 구조만 유지 (.gitkeep)
!output/.gitkeep
!output/generated_images/
!output/generated_images/.gitkeep
!output/generated_images/pending_review/
!output/generated_images/pending_review/.gitkeep
!output/cover_images/
!output/cover_images/.gitkeep
!output/naia_queues/.gitkeep
!output/exports/.gitkeep
