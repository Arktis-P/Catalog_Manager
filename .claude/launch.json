{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "catalogue-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 4173,
      "cwd": "frontend"
    },
    {
      "name": "catalogue-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "catalogue-backend",
      "runtimeExecutable": "../.venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000,
      "cwd": "backend"
    }
  ]
}
