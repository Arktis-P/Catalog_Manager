# Network routing for Danbooru API (pybooru) only.
# Copy to network.env and fill in NordVPN service credentials.
#
# Goal: Catalogue Manager uses NordVPN SOCKS5 for Danbooru only.
#       NordVPN desktop app does NOT need to run.
#       Other apps on this PC stay on direct internet.
#
# --- Step 1: Get NordVPN *service* credentials (not login email/password) ---
#   https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/
#   Click "Set up NordVPN manually" -> verify email -> copy service username/password
#
# --- Step 2: Fill the four lines below ---
# Recommended server for Korea: amsterdam.nl.socks.nordhold.net (port 1080)
# Other servers: nl.socks.nordhold.net, se.socks.nordhold.net, us.socks.nordhold.net
#
# --- Step 3: Run scripts\setup_nord_proxy.bat to verify ---

nord_socks_host=amsterdam.nl.socks.nordhold.net
nord_socks_port=1080
nord_service_username=your_nord_service_username
nord_service_password=your_nord_service_password
no_proxy=127.0.0.1,localhost

# Advanced: override with a full proxy URL instead of Nord fields above
# https_proxy=socks5://user:pass@host:1080
# http_proxy=
